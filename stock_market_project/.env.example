# Environment variables for API keys
# Get your API keys from the respective services:

# NewsAPI (for comprehensive news): https://newsapi.org/
# Free tier: 100 requests/day
NEWS_API_KEY=your_newsapi_key_here

# Alpha Vantage (alternative for stock data): https://www.alphavantage.co/
# Free tier: 5 requests/minute, 500 requests/day
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Optional: Polygon.io API key for more advanced stock data
# Free tier available: https://polygon.io/
POLYGON_API_KEY=your_polygon_key_here